<resource xmlns="http://midpoint.evolveum.com/xml/ns/public/common/common-3"
          xmlns:c="http://midpoint.evolveum.com/xml/ns/public/common/common-3"
          xmlns:org="http://midpoint.evolveum.com/xml/ns/public/common/org-3"
          xmlns:q="http://prism.evolveum.com/xml/ns/public/query-3"
          xmlns:ri="http://midpoint.evolveum.com/xml/ns/public/resource/instance-3"
          oid="ab76a143-f425-4d9d-bb3b-6076fe8e4452">
    <name>resource-g-template</name>
    <abstract>true</abstract>
    <connectorRef oid="will-be-supplied-by-the-test-code"/>
    <schema>
        <generationConstraints>
            <generateObjectClass>ri:AccountObjectClass</generateObjectClass>
            <generateObjectClass>ri:CustomGrpObjectClass</generateObjectClass>
        </generationConstraints>
    </schema>
    <schemaHandling>
        <objectType>
            <kind>account</kind>
            <intent>user</intent>
            <displayName>user</displayName>
            <delineation>
                <objectClass>ri:AccountObjectClass</objectClass>
            </delineation>
            <focus>
                <type>UserType</type>
            </focus>
            <attribute>
                <ref>ri:name</ref>
                <inbound>
                    <name>name-in</name>
                    <strength>strong</strength>
                    <target>
                        <path>name</path>
                    </target>
                </inbound>
            </attribute>
            <attribute>
                <ref>ri:firstName</ref>
                <inbound>
                    <name>FirstName-in</name>
                    <strength>strong</strength>
                    <target>
                        <path>givenName</path>
                    </target>
                </inbound>
            </attribute>
            <attribute>
                <ref>ri:lastName</ref>
                <inbound>
                    <strength>strong</strength>
                    <name>LastName-in</name>
                    <target>
                        <path>familyName</path>
                    </target>
                </inbound>
            </attribute>
            <correlation>
                <correlators>
                    <items>
                        <name>Name</name>
                        <item>
                            <ref>name</ref>
                        </item>
                    </items>
                </correlators>
            </correlation>
            <synchronization>
                <reaction>
                    <situation>linked</situation>
                    <actions>
                        <synchronize/>
                    </actions>
                </reaction>
                <reaction>
                    <situation>unmatched</situation>
                    <actions>
                        <addFocus/>
                    </actions>
                </reaction>
                <reaction>
                    <situation>deleted</situation>
                    <actions>
                        <inactivateFocus/>
                    </actions>
                </reaction>
            </synchronization>
        </objectType>
        <objectType>
            <kind>entitlement</kind>
            <intent>group</intent>
            <displayName>group</displayName>
            <delineation>
                <objectClass>ri:CustomGrpObjectClass</objectClass>
            </delineation>
            <focus>
                <type>RoleType</type>
            </focus>
            <attribute>
                <ref>ri:name</ref>
                <inbound>
                    <name>name-in</name>
                    <strength>strong</strength>
                    <target>
                        <path>name</path>
                    </target>
                </inbound>
            </attribute>
            <attribute>
                <ref>ri:id</ref>
                <inbound>
                    <name>id-in</name>
                    <strength>strong</strength>
                    <target>
                        <path>identifier</path>
                    </target>
                </inbound>
            </attribute>
            <correlation>
                <correlators>
                    <items>
                        <name>id</name>
                        <item>
                            <ref>identifier</ref>
                        </item>
                    </items>
                </correlators>
            </correlation>
            <synchronization>
                <reaction>
                    <situation>linked</situation>
                    <actions>
                        <synchronize/>
                    </actions>
                </reaction>
                <reaction>
                    <situation>unmatched</situation>
                    <actions>
                        <addFocus/>
                    </actions>
                </reaction>
                <reaction>
                    <situation>deleted</situation>
                    <actions>
                        <inactivateFocus/>
                    </actions>
                </reaction>
            </synchronization>
        </objectType>
        <associationType>
            <name>grp-member</name>
            <displayName>Group Member</displayName>
            <subject>
                <objectType>
                    <kind>account</kind>
                    <intent>user</intent>
                </objectType>
                <association>
                    <ref>ri:member</ref>
                    <inbound>
                        <name>Grp-Member</name>
                        <strength>strong</strength>
                        <expression>
                            <associationSynchronization>
                                <objectRef>
                                    <ref>ri:member</ref>
                                    <correlator/>
                                    <mapping>
                                        <name>GrpMember</name>
                                        <expression>
                                            <shadowOwnerReferenceSearch/>
                                        </expression>
                                        <target>
                                            <path>targetRef</path>
                                        </target>
                                    </mapping>
                                </objectRef>
                                <synchronization>
                                    <reaction>
                                        <situation>unmatched</situation>
                                        <actions>
                                            <addFocusValue/>
                                        </actions>
                                    </reaction>
                                    <reaction>
                                        <situation>matched</situation>
                                        <actions>
                                            <synchronize/>
                                        </actions>
                                    </reaction>
                                </synchronization>
                            </associationSynchronization>
                        </expression>
                    </inbound>
                    <sourceAttributeRef>ri:member</sourceAttributeRef>
                </association>
            </subject>
            <object>
                <objectType>
                    <kind>entitlement</kind>
                    <intent>group</intent>
                </objectType>
            </object>
        </associationType>
    </schemaHandling>
    <capabilities>
        <c:configured xmlns="http://midpoint.evolveum.com/xml/ns/public/resource/capabilities-3">
            <references>
                <type>  <!-- id is not defined here-->
                    <name>ri:member</name>
                    <subject>
                        <delineation>
                            <objectClass>ri:AccountObjectClass</objectClass>
                        </delineation>
                        <primaryBindingAttributeRef>ri:name</primaryBindingAttributeRef>
                        <localItemName>ri:member</localItemName>
                    </subject>
                    <object>
                        <delineation>
                            <objectClass>ri:CustomGrpObjectClass</objectClass>
                        </delineation>
                        <primaryBindingAttributeRef>ri:member</primaryBindingAttributeRef>
                    </object>
                    <direction>objectToSubject</direction>
                </type>
            </references>
        </c:configured>
    </capabilities>
</resource>
