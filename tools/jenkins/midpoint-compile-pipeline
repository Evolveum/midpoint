def verbose = params.VERBOSE ?: '0'

// Make the cpuLimit integer from String Jenkins job parameter.
def cpuLimit = (params.BUILDER_CPU ?: '2').toInteger() * 2
// Request quarter of the limit (min 1) to reduce reserved capacity, allowing more concurrent pods to be scheduled.
def cpuRequest = Math.max(1, cpuLimit.intdiv(4))

podTemplate(
        nodeSelector: params.NODE_SELECTOR,
        activeDeadlineSeconds: 900,
        idleMinutes: 1,
        volumes: [ persistentVolumeClaim(claimName: "midpoint-compile-pipeline-m2repo", mountPath: "/root/.m2/repository")],
        //workspaceVolume: dynamicPVC(requestsSize: "10Gi"),
        workspaceVolume: persistentVolumeClaimWorkspaceVolume(claimName: "midpoint-compile-pipeline-workspace"),
        containers: [
                containerTemplate(name: 'jnlp',
                        image: 'jenkins/inbound-agent:4.13-2-alpine',
                        runAsUser: '0',
                        resourceRequestCpu: '500m',
                        resourceLimitCpu: '2',
                        resourceLimitMemory: '4Gi'),
                containerTemplate(name: 'maven',
                        image: params.BUILDER_IMAGE ?: 'maven:3.8.5-openjdk-17',
                        runAsUser: '0',
                        ttyEnabled: true,
                        command: 'cat',
                        resourceRequestCpu: "${cpuRequest}",
                        resourceLimitCpu: "${cpuLimit}",
                        resourceRequestMemory: '4Gi',
                        resourceLimitMemory: '4Gi')
        ]
) {
    node(POD_LABEL) {
        try {
            stage("checkout") {
                sh """#!/bin/bash -ex
                    if [ "${verbose}" -ge 1 ]
                    then
                        df -h
                    fi
                """
                def checkoutExtensions = [
                    // Cleans up files not in Git, e.g. previous build
                    [$class: 'CleanBeforeCheckout'],
                    // Forces the local branch to match the remote exactly, in case the history is rewritten
                    [$class: 'PruneStaleBranch'],
                    [$class: 'CloneOption', honorRefspec: true, noTags: false, reference: '', shallow: false]
                ]
                if (params.CLEAN_WORKSPACE) {
                    echo "CLEAN_WORKSPACE is true: Adding WipeWorkspace extension."
                    checkoutExtensions.add([$class: 'WipeWorkspace'])
                }
                checkout([
                    $class: 'GitSCM',
                    branches: [[name: params.BRANCH ?: 'master']],
                    userRemoteConfigs: scm.userRemoteConfigs,
                    extensions: checkoutExtensions
                ])
            }
            stage("compile") {
                container('maven') {
                    if (params.CLEAN_M2_REPOSITORY) {
                        sh "rm -rf ~/.m2/repository/*"
                    }

                    sh "rm -rf ~/.m2/repository/com/evolveum"

                    sh """#!/bin/bash -ex
                        if [ "${verbose}" -ge 1 ]
                        then
                            id
                            env | sort
                            mvn --version
                        fi

                        mvn -B -ntp -U clean package -DskipTests -P -dist
                    """
                }
            }
            currentBuild.result = 'SUCCESS'
        } catch (Exception e) {
            currentBuild.result = 'FAILURE' // error below will not set result for mailer!
            error "Marking build as FAILURE because of: ${e}"
        } finally {
            try {
                // Very basic mails, later we can use https://plugins.jenkins.io/email-ext/
                step([$class: 'Mailer',
                    notifyEveryUnstableBuild: true,
                    recipients: env.DEFAULT_MAIL_RECIPIENT,
                    sendToIndividuals: false])

                sh """#!/bin/bash -ex
                    if [ "${verbose}" -ge 1 ]
                    then
                        df -h
                    fi
                """
            } catch (Exception e) {
                println 'Could not send email: ' + e
            }
        }
    }
}
