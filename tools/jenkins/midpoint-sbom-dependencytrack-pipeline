def verbose = params.VERBOSE ?: '0'

// Make the cpuLimit integer from String Jenkins job parameter.
def cpuLimit = (params.BUILDER_CPU ?: '4').toInteger() * 2
// Request quarter of the limit (min 1) to reduce reserved capacity, allowing more concurrent pods to be scheduled.
def cpuRequest = Math.max(1, cpuLimit.intdiv(4))

podTemplate(
        nodeSelector: params.NODE_SELECTOR,
        activeDeadlineSeconds: 1800,
        idleMinutes: 1,
        workspaceVolume: dynamicPVC(requestsSize: "10Gi"),
        containers: [
                containerTemplate(name: 'jnlp',
                        image: 'jenkins/inbound-agent:4.13-2-alpine',
                        runAsUser: '0',
                        resourceRequestCpu: '500m',
                        resourceLimitCpu: '2',
                        resourceLimitMemory: '4Gi'),
                containerTemplate(name: 'maven',
                        image: params.BUILDER_IMAGE ?: 'maven:3.8.5-openjdk-17',
                        runAsUser: '0',
                        ttyEnabled: true,
                        command: 'cat',
                        resourceRequestCpu: "${cpuRequest}",
                        resourceLimitCpu: "${cpuLimit}",
                        resourceRequestMemory: '8Gi',
                        resourceLimitMemory: '8Gi')
        ]
) {
    node(POD_LABEL) {
        try {
            stage("checkout") {
                sh """#!/bin/bash -ex
                    if [ "${verbose}" -ge 1 ]
                    then
                        df -h
                    fi
                """
                retry(3) {
                    git branch: params.BRANCH ?: 'master',
                            url: 'https://github.com/Evolveum/midpoint.git'
                }
            }
            stage("analyze") {
                container('maven') {
                    withCredentials([usernamePassword(
                            credentialsId:"dependencyTrack",
                            usernameVariable:"DTRACK_URL",
                            passwordVariable: "DTRACK_TOKEN"),
                            file(credentialsId: 'evolveum-root-ca', variable: 'EVOLVEUM_ROOT_CA')
                            ]) {
                        sh """#!/bin/bash -ex
                            # Import internal CA into Java truststore for DependencyTrack HTTPS
                            keytool -importcert -noprompt -cacerts -storepass changeit -alias evolveum-root-ca -file \$EVOLVEUM_ROOT_CA

                            if [ "${verbose}" -ge 1 ]
                            then
                                id
                                env | sort
                                mvn --version
                            fi

                            mvn -B -ntp -U clean install  -DskipTests -P dist,sbom,dependencytrack
                        """
                    }
                }
            }

            currentBuild.result = 'SUCCESS'
        } catch (Exception e) {
            currentBuild.result = 'FAILURE' // error below will not set result for mailer!
            error "Marking build as FAILURE because of: ${e}"
        } finally {
            try {
                // Very basic mails, later we can use https://plugins.jenkins.io/email-ext/
                step([$class: 'Mailer',
                    notifyEveryUnstableBuild: true,
                    recipients: env.DEFAULT_MAIL_RECIPIENT,
                    sendToIndividuals: false])

                sh """#!/bin/bash -ex
                    if [ "${verbose}" -ge 1 ]
                    then
                        df -h
                    fi
                """
            } catch (Exception e) {
                println 'Could not send email: ' + e
            }
        }
    }
}
