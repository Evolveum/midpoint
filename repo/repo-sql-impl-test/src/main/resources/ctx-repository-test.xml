<beans xmlns="http://www.springframework.org/schema/beans"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.springframework.org/schema/beans
            http://www.springframework.org/schema/beans/spring-beans-3.0.xsd"
        default-lazy-init="true">

    <!--
    Use the Java configuration selector instead of registering SQL and Sqale
    configurations directly, so their repository-type conditions are applied.
    -->
    <bean id="testRepositoryBeanConfig"
            class="com.evolveum.midpoint.repo.sql.testing.TestRepositoryBeanConfig"/>
</beans>
