<objectTemplate oid="3c0a5c4a-5041-401f-9c46-000000004812"
        xmlns="http://midpoint.evolveum.com/xml/ns/public/common/common-3">
    <name>User Template MID-4812</name>

    <mapping>
        <source>
            <path>givenName</path>
        </source>
        <source>
            <path>familyName</path>
        </source>
        <expression>
            <script>
                <code>
                    'This is ' + givenName + ' ' + familyName + '.'
                </code>
            </script>
        </expression>
        <target>
            <path>description</path>
        </target>
    </mapping>
</objectTemplate>
