<?xml version="1.0" encoding="UTF-8"?>
<objectTemplate oid="98d22012-5bba-4f83-b7d6-5ad3e2cf2101"
        xmlns="http://midpoint.evolveum.com/xml/ns/public/common/common-3"
        xmlns:c="http://midpoint.evolveum.com/xml/ns/public/common/common-3"
        xmlns:q="http://prism.evolveum.com/xml/ns/public/query-3">
    <name>MQL service-only template</name>
    <mapping>
        <name>service-owner-mql</name><strength>strong</strength>
        <source><name>name</name><path>$focus/name</path></source>
        <expression><assignmentTargetSearch><targetType>c:ServiceType</targetType><filter><q:text>extension/initialOwnerName exists and extension/initialOwnerName = `name`</q:text></filter><assignmentProperties><relation>owner</relation></assignmentProperties></assignmentTargetSearch></expression>
        <target><path>$focus/assignment</path><set><predefined>none</predefined></set></target>
        <condition><script><code>java.lang.Thread.sleep(Integer.getInteger("midpoint.mqlRace.conditionSleepMs", 1)); return name != null;</code></script></condition>
    </mapping>
</objectTemplate>
