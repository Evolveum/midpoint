<?xml version="1.0" encoding="UTF-8"?>
<objectTemplate oid="96a68747-f51a-41fc-96e6-5c27ad6f8502"
        xmlns="http://midpoint.evolveum.com/xml/ns/public/common/common-3"
        xmlns:c="http://midpoint.evolveum.com/xml/ns/public/common/common-3"
        xmlns:q="http://prism.evolveum.com/xml/ns/public/query-3"
        xmlns:race="http://midpoint.evolveum.com/xml/ns/test/mql-concurrency-race">
    <name>XML concurrency single template</name>

    <mapping>
        <name>service-owner-xml</name>
        <strength>strong</strength>
        <source><name>name</name><path>$focus/name</path></source>
        <expression>
            <assignmentTargetSearch>
                <targetType>c:ServiceType</targetType>
                <filter><q:equal><q:path>extension/race:initialOwnerName</q:path><expression><script><code>java.lang.Thread.sleep(Integer.getInteger("midpoint.mqlRace.scriptSleepMs", 3)); return name;</code></script></expression></q:equal></filter>
                <assignmentProperties><relation>owner</relation></assignmentProperties>
            </assignmentTargetSearch>
        </expression>
        <target><path>$focus/assignment</path><set><predefined>none</predefined></set></target>
        <condition><script><code>java.lang.Thread.sleep(Integer.getInteger("midpoint.mqlRace.conditionSleepMs", 1)); return name != null;</code></script></condition>
    </mapping>

    <mapping>
        <name>org-member-by-workplace-xml</name>
        <strength>strong</strength>
        <source><name>workplaceId</name><path>$focus/extension/race:workplaceId</path></source>
        <expression><assignmentTargetSearch><targetType>c:OrgType</targetType><filter><q:equal><q:path>identifier</q:path><expression><path>$workplaceId</path></expression></q:equal></filter></assignmentTargetSearch></expression>
        <target><path>$focus/assignment</path><set><predefined>none</predefined></set></target>
        <condition><script><code>java.lang.Thread.sleep(Integer.getInteger("midpoint.mqlRace.conditionSleepMs", 1)); return workplaceId != null;</code></script></condition>
    </mapping>

    <mapping>
        <name>org-manager-by-personal-number-xml</name>
        <strength>strong</strength>
        <source><name>personalNumber</name><path>$focus/personalNumber</path></source>
        <expression>
            <assignmentTargetSearch>
                <targetType>c:OrgType</targetType>
        <filter><q:equal><q:path>extension/race:managerPersonalNumber</q:path><expression><path>$personalNumber</path></expression></q:equal></filter>
                <assignmentProperties><relation>manager</relation></assignmentProperties>
            </assignmentTargetSearch>
        </expression>
        <target><path>$focus/assignment</path><set><predefined>none</predefined></set></target>
        <condition><script><code>java.lang.Thread.sleep(Integer.getInteger("midpoint.mqlRace.conditionSleepMs", 1)); return personalNumber != null;</code></script></condition>
    </mapping>

    <mapping>
        <name>role-by-sap-xml</name>
        <strength>strong</strength>
        <source><name>dynamicCode1</name><path>$focus/extension/race:sapCode1</path></source>
        <expression>
            <assignmentTargetSearch>
                <targetType>c:RoleType</targetType>
                <filter><q:and><q:equal><q:path>extension/race:exRoleSapCode1</q:path><expression><script><code>java.lang.Thread.sleep(Integer.getInteger("midpoint.mqlRace.scriptSleepMs", 3)); return dynamicCode1;</code></script></expression></q:equal><q:equal><q:path>extension/race:exRoleSapCode</q:path><q:value>yyy</q:value></q:equal><q:equal><q:path>extension/race:exRoleApplicationInstanceName</q:path><q:value>FSD</q:value></q:equal><q:equal><q:path>extension/race:exRoleVariant</q:path><q:value>PRIMARY</q:value></q:equal></q:and></filter>
            </assignmentTargetSearch>
        </expression>
        <target><path>$focus/assignment</path><set><predefined>none</predefined></set></target>
        <condition><script><code>java.lang.Thread.sleep(Integer.getInteger("midpoint.mqlRace.conditionSleepMs", 1)); return dynamicCode1 != null;</code></script></condition>
    </mapping>
</objectTemplate>
