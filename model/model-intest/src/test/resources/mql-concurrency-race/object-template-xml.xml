    <mapping>
        <name>role-by-sap-xml</name>
        <strength>strong</strength>
        <source>
            <name>dynamicCode1</name>
            <path>$focus/extension/race:sapCode1</path>
        </source>
        <expression>
            <assignmentTargetSearch>
                <targetType>c:RoleType</targetType>
                <filter>
                    <q:and>
                        <q:equal>
                            <q:path>extension/race:exRoleSapCode1</q:path>
                            <expression>
                                <script>
