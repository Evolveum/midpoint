<objectTemplate oid="f6d8bb9b-44f7-4c1b-a8f7-fce29f092f5d"
        xmlns="http://midpoint.evolveum.com/xml/ns/public/common/common-3"
        xmlns:c="http://midpoint.evolveum.com/xml/ns/public/common/common-3"
        xmlns:q="http://prism.evolveum.com/xml/ns/public/query-3"
        xmlns:race="http://midpoint.evolveum.com/xml/ns/test/mql-concurrency-race">
    <name>XML control concurrency race template</name>

    <mapping>
        <name>service-owner-xml</name>
        <strength>strong</strength>
        <source>
            <name>name</name>
            <path>$focus/name</path>
        </source>
        <expression>
            <assignmentTargetSearch>
                <targetType>c:ServiceType</targetType>
                <filter>
                    <q:equal>
                        <q:path>extension/race:initialOwnerName</q:path>
                        <expression>
                            <script>
                                <code><![CDATA[
java.lang.Thread.sleep(Integer.getInteger("midpoint.mqlRace.scriptSleepMs", 3));
return name;
                                ]]></code>
                            </script>
                        </expression>
                    </q:equal>
                </filter>
                <assignmentProperties>
                    <relation>owner</relation>
                </assignmentProperties>
            </assignmentTargetSearch>
        </expression>
        <target>
            <path>$focus/assignment</path>
            <set>
                <predefined>none</predefined>
            </set>
        </target>
        <condition>
            <script>
                <code><![CDATA[
java.lang.Thread.sleep(Integer.getInteger("midpoint.mqlRace.conditionSleepMs", 1));
return name != null;
                ]]></code>
            </script>
        </condition>
    </mapping>

