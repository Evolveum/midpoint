<role xmlns="http://midpoint.evolveum.com/xml/ns/public/common/common-3"
        xmlns:q="http://prism.evolveum.com/xml/ns/public/query-3"
        oid="26bb2408-124c-11f1-a7bb-074bba115e64">
    <name>safe-auto-good-mel</name>
    <documentation>
        Auto-assigned role that contains only "correct" mappings w.r.t. `safe` expression profile.
    </documentation>
    <assignment>
        <targetRef oid="2a68ff58-b009-11f0-9b5e-236da66bcdb4" type="ArchetypeType"/>
    </assignment>
    <autoassign>
        <enabled>true</enabled>
        <focus>
            <mapping id="333">
                <condition>
                    <script>
                        <language>http://midpoint.evolveum.com/xml/ns/public/expression/language#mel</language>
                        <code>focus.costCenter == 'safe'</code>
                    </script>
                </condition>
            </mapping>
            <selector>
                <type>UserType</type>
            </selector>
        </focus>
    </autoassign>
</role>
