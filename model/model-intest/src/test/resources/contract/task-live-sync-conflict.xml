<task xmlns="http://midpoint.evolveum.com/xml/ns/public/common/common-3"
        xmlns:ri="http://midpoint.evolveum.com/xml/ns/public/resource/instance-3"
        oid="56b0caba-9682-409b-815b-878029b42ef0">

    <name>task-live-sync-dummy-conflict</name>

    <ownerRef oid="00000000-0000-0000-0000-000000000002"/>
    <executionState>runnable</executionState>
    <executionEnvironment>
        <conflictResolution>
            <action>restart</action>
        </conflictResolution>
    </executionEnvironment>
    <schedule>
        <recurrence>recurring</recurrence>
        <!-- every second -->
        <cronLikePattern>* * * ? * *</cronLikePattern>
    </schedule>
    <activity>
        <work>
            <liveSynchronization>
                <resourceObjects>
                    <resourceRef oid="f6ff3f3f-290e-475c-b1aa-96bad5058322"/>
                    <kind>account</kind>
                    <intent>default</intent>
                </resourceObjects>
            </liveSynchronization>
        </work>
        <!--<reporting>-->
        <!--    <tracing>-->
        <!--        <tracingProfile>-->
        <!--            <ref>functional-model-logging</ref>-->
        <!--        </tracingProfile>-->
        <!--    </tracing>-->
        <!--</reporting>-->
    </activity>
</task>
