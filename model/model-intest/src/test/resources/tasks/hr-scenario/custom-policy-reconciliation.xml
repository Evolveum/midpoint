<!--
  HR source reconciliation modelling a "restart twice, then suspend on the third attempt" policy.
  Cleaned-up variant of custom-task.xml. Composite, distributed into subtasks:
   - child "simulate": reconciliation in preview mode with two policies on the deleted-users threshold:
       * max-deleted (order 20): restartActivity when >= 5 users would be deleted (counter cleared on restart)
       * max-restarts (order 10): suspendTask once the activity has been attempted more than twice
         (executionAttempts exceeds 2 -> triggers on the 3rd attempt; lower order so it wins over the restart)
   - child "execute": reconciliation in full mode (no policy)
  The source resource deletes the focus (user) when its account is removed (deleted -> deleteFocus).
-->
<task xmlns="http://midpoint.evolveum.com/xml/ns/public/common/common-3"
        oid="e4f00000-0000-0000-0000-000000000002">
    <name>custom-policy-reconciliation</name>
    <assignment>
        <targetRef oid="00000000-0000-0000-0000-000000000528" type="ArchetypeType"/>
    </assignment>
    <ownerRef oid="00000000-0000-0000-0000-000000000002" type="UserType"/>
    <executionState>runnable</executionState>
    <activity>
        <composition>
            <activity>
                <order>1</order>
                <identifier>simulate</identifier>
                <work>
                    <reconciliation>
                        <resourceObjects>
                            <resourceRef oid="c1a70000-0000-0000-0000-000000000001"/>
                            <kind>account</kind>
                            <intent>default</intent>
                        </resourceObjects>
                    </reconciliation>
                </work>
                <execution>
                    <mode>preview</mode>
                </execution>
                <reporting>
                    <simulationResult>
                        <enabled>false</enabled>
                    </simulationResult>
                </reporting>
                <distribution>
                    <workerThreads>3</workerThreads>
                </distribution>
                <policies>
                    <policy>
                        <name>max-restarts</name>
                        <order>10</order>
                        <policyConstraints>
                            <executionAttempts>
                                <exceeds>2</exceeds>
                            </executionAttempts>
                        </policyConstraints>
                        <policyActions>
                            <notification/>
                            <suspendTask/>
                        </policyActions>
                    </policy>
                    <policy>
                        <name>max-deleted</name>
                        <order>20</order>
                        <policyConstraints>
                            <modification>
                                <operation>delete</operation>
                            </modification>
                        </policyConstraints>
                        <policyThreshold>
                            <lowWaterMark>
                                <count>5</count>
                            </lowWaterMark>
                        </policyThreshold>
                        <policyActions>
                            <notification/>
                            <restartActivity>
                                <delay>PT2S</delay>
                            </restartActivity>
                        </policyActions>
                    </policy>
                </policies>
                <tailoring>
                    <change>
                        <reference>resourceObjectsPreview</reference>
                        <controlFlow>
                            <processingOption>process</processingOption>
                        </controlFlow>
                    </change>
                    <change>
                        <reference>remainingShadowsPreview</reference>
                        <controlFlow>
                            <processingOption>process</processingOption>
                        </controlFlow>
                    </change>
                </tailoring>
            </activity>
            <activity>
                <order>2</order>
                <identifier>execute</identifier>
                <work>
                    <reconciliation>
                        <resourceObjects>
                            <resourceRef oid="c1a70000-0000-0000-0000-000000000001"/>
                            <kind>account</kind>
                            <intent>default</intent>
                        </resourceObjects>
                    </reconciliation>
                </work>
                <execution>
                    <mode>full</mode>
                </execution>
                <distribution>
                    <workerThreads>3</workerThreads>
                </distribution>
            </activity>
        </composition>
        <distribution>
            <subtasks/>
        </distribution>
    </activity>
</task>
