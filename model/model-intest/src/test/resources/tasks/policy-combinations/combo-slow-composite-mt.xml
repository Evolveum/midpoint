<!-- Composite: first(noOp) / main(import SLOW, multithreaded) / last(noOp). For executionTime combos. -->
<task xmlns="http://midpoint.evolveum.com/xml/ns/public/common/common-3"
        oid="e3f00000-0000-0000-0000-000000000011">
    <name>combo-slow-composite-mt</name>
    <ownerRef oid="00000000-0000-0000-0000-000000000002" type="UserType"/>
    <executionState>runnable</executionState>
    <activity>
        <composition>
            <activity>
                <order>1</order>
                <identifier>first</identifier>
                <work>
                    <noOp>
                        <steps>3</steps>
                        <delay>100</delay>
                    </noOp>
                </work>
            </activity>
            <activity>
                <order>2</order>
                <identifier>main</identifier>
                <work>
                    <import>
                        <resourceObjects>
                            <resourceRef oid="1645e542-d034-4118-b8af-97c4d22d81d6"/>
                            <kind>account</kind>
                            <intent>default</intent>
                        </resourceObjects>
                    </import>
                </work>
                <distribution>
                    <workerThreads>3</workerThreads>
                </distribution>
            </activity>
            <activity>
                <order>3</order>
                <identifier>last</identifier>
                <work>
                    <noOp>
                        <steps>3</steps>
                        <delay>100</delay>
                    </noOp>
                </work>
            </activity>
        </composition>
    </activity>
</task>
