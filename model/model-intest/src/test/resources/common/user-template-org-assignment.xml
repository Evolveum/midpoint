<objectTemplate oid="10000000-0000-0000-0000-000000000444"
   xmlns:xsi='http://www.w3.org/2001/XMLSchema-instance'
   xmlns='http://midpoint.evolveum.com/xml/ns/public/common/common-3'
   xmlns:c='http://midpoint.evolveum.com/xml/ns/public/common/common-3'
   xmlns:t="http://prism.evolveum.com/xml/ns/public/types-3"
   xmlns:q="http://prism.evolveum.com/xml/ns/public/query-3"
   >
    <name>User Template giving org assignments</name>

    <mapping>
        <name>Assign orgs from authoritative source</name>
        <authoritative>true</authoritative>
        <source>
            <c:path>$user/organizationalUnit</c:path>
        </source>
        <expression>
            <assignmentTargetSearch>
                <targetType>c:OrgType</targetType>
                <filter>
                    <q:equal>
                        <q:path>name</q:path>
                        <expression>
                            <c:path>$organizationalUnit</c:path>
                        </expression>
                    </q:equal>
                </filter>
            </assignmentTargetSearch>
        </expression>
        <target>
            <c:path>assignment</c:path>
        </target>
    </mapping>

    <!-- MID-3545 -->
    <mapping>
        <name>autorole</name>
        <authoritative>true</authoritative>
        <source>
            <c:path>$user/subtype</c:path>
        </source>
        <expression>
            <assignmentTargetSearch>
                <targetType>RoleType</targetType>
                <filter>
                    <q:equal>
                        <q:path>name</q:path>
                        <expression>
                            <script>
                                <language>http://midpoint.evolveum.com/xml/ns/public/expression/language#mel</language>
                                <code>subtype.substring(5)</code>
                            </script>
                        </expression>
                    </q:equal>
                </filter>
                <defaultTargetRef oid="12345111-1111-2222-1111-121212111112" type="RoleType"/> <!-- Empty Role -->
            </assignmentTargetSearch>
        </expression>
        <target>
            <c:path>assignment</c:path>
        </target>
        <condition>
            <trace>true</trace>
            <script>
                <language>http://midpoint.evolveum.com/xml/ns/public/expression/language#mel</language>
                <code>subtype.startsWith('ROLE:')</code>
            </script>
        </condition>
    </mapping>

</objectTemplate>
