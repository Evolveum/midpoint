<!-- User template with iteration starting at 5, no `end`, so effective limit is start + maxIterations = 7. -->

<objectTemplate oid="10000000-0000-0000-0000-0000000d0020"
   xmlns='http://midpoint.evolveum.com/xml/ns/public/common/common-3'>
    <name>user-template-iteration-start</name>
    <iterationSpecification>
        <start>5</start>
        <maxIterations>2</maxIterations>
    </iterationSpecification>
    <mapping>
        <source>
            <path>givenName</path>
        </source>
        <source>
            <path>familyName</path>
        </source>
        <expression>
            <script>
                <code>
                    basic.concatName(givenName, familyName) + iterationToken
                </code>
             </script>
        </expression>
        <target>
            <path>name</path>
        </target>
    </mapping>
</objectTemplate>
