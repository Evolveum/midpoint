<!-- Strictly speaking, this expression should not work.
     Conditional (?:) requires the same type in both branches.
     Null is not string, therefore the first conditional should fail.
     But it works. -->
<script xmlns="http://midpoint.evolveum.com/xml/ns/public/common/common-3">
    <language>http://midpoint.evolveum.com/xml/ns/public/expression/language#mel</language>
    <code>
        isNull(input) ? nil() : 'We have ' + input
    </code>
</script>
