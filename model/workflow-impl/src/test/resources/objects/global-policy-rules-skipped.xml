<systemConfiguration xmlns="http://midpoint.evolveum.com/xml/ns/public/common/common-3"
        xmlns:q="http://prism.evolveum.com/xml/ns/public/query-3">

    <globalPolicyRule>
        <name>role-inducement-add-manual</name>
        <policyConstraints>
            <presentation>
                <shortMessage>
                    <fallbackMessage>Changing inducement</fallbackMessage>
                </shortMessage>
            </presentation>
            <modification>
                <operation>add</operation>
                <item>inducement</item>
            </modification>
        </policyConstraints>
        <policyActions>
            <approval>
                <processSpecification>
                    <deltaFrom>
                        <itemValue>inducement</itemValue>
                    </deltaFrom>
                </processSpecification>
                <compositionStrategy>
                    <order>10</order>
                </compositionStrategy>
                <approverRef oid="00000000-0000-0000-0000-000000000002" type="UserType"/>
            </approval>
        </policyActions>
        <focusSelector>
            <type>RoleType</type>
            <filter>
                <q:equal>
                    <q:path>name</q:path>
                    <q:value>mid-11101-add-inducement-manual-after-skipped</q:value>
                </q:equal>
            </filter>
        </focusSelector>
    </globalPolicyRule>

    <globalPolicyRule>
        <name>role-add-skipped</name>
        <policyConstraints>
            <modification>
                <operation>add</operation>
            </modification>
        </policyConstraints>
        <policyActions>
            <approval>
                <compositionStrategy>
                    <order>20</order>
                </compositionStrategy>
                <approvalSchema>
                    <stage>
                        <outcomeIfNoApprovers>skip</outcomeIfNoApprovers>
                    </stage>
                </approvalSchema>
            </approval>
        </policyActions>
        <focusSelector>
            <type>RoleType</type>
        </focusSelector>
    </globalPolicyRule>

    <globalPolicyRule>
        <name>role-inducement-add-skipped</name>
        <policyConstraints>
            <modification>
                <operation>add</operation>
                <item>inducement</item>
            </modification>
        </policyConstraints>
        <policyActions>
            <approval>
                <processSpecification>
                    <deltaFrom>
                        <itemValue>inducement</itemValue>
                    </deltaFrom>
                </processSpecification>
                <compositionStrategy>
                    <order>30</order>
                </compositionStrategy>
                <approvalSchema>
                    <stage>
                        <outcomeIfNoApprovers>skip</outcomeIfNoApprovers>
                    </stage>
                </approvalSchema>
            </approval>
        </policyActions>
        <focusSelector>
            <type>RoleType</type>
        </focusSelector>
    </globalPolicyRule>

</systemConfiguration>
