<objects xmlns="http://midpoint.evolveum.com/xml/ns/public/common/common-3"
         xmlns:c="http://midpoint.evolveum.com/xml/ns/public/common/common-3">

    <role oid="11111111-1111-1111-1111-000000110082">
        <name>Preview policy normal role</name>
    </role>

    <archetype oid="22222222-2222-2222-2222-000000110082">
        <name>Preview policy Org archetype</name>

        <assignment>
            <assignmentRelation>
                <holderType>OrgType</holderType>
            </assignmentRelation>
        </assignment>

        <inducement>
            <focusMappings>
                <mapping>
                    <name>force assignment path variables</name>
                    <expression>
                        <value>Preview policy focus mapping fired</value>
                    </expression>
                    <target>
                        <c:path>description</c:path>
                    </target>
                </mapping>
            </focusMappings>

            <policyRule>
                <policyConstraints>
                    <modification>
                        <item>roleMembershipRef</item>
                    </modification>
                </policyConstraints>
                <policyActions>
                    <record/>
                </policyActions>
            </policyRule>

            <focusType>OrgType</focusType>
        </inducement>
    </archetype>

    <org oid="33333333-3333-3333-3333-000000110082">
        <name>Preview policy org</name>
        <assignment>
            <targetRef oid="22222222-2222-2222-2222-000000110082"
                       type="c:ArchetypeType"/>
        </assignment>
    </org>

</objects>
